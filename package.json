{
  "name": "my-mental-health-buddy",
  "version": "1.0.0",
  "description": "Full-stack AI mental health companion",
  "main": "server/index.mjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.mjs",
    "dev:client": "npm run dev --prefix client",
    "start": "node server/index.mjs"
  },
  "dependencies": {
    "@sentry/node": "^7.66.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "openai": "^6.9.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
