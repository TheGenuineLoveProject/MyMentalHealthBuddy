{
  "name": "mymentalhealthbuddy-monorepo",
  "version": "1.1.0",
  "private": true,
  "workspaces": ["apps/*"],
  "engines": { "node": ">=20 <21" },
  "scripts": {
    "dev:server": "npm --prefix apps/server run dev",
    "dev:client": "npm --prefix apps/client run dev",
    "type-check": "echo \"(optional) add TS later\"",
    "health": "node scripts/health.js",
    "start:all": "concurrently -k -n server,client -c auto \"npm run dev:server\" \"wait-on http://localhost:5000/health && npm run dev:client\"",
    "build:all": "npm --prefix apps/client run build",
    "preview": "npm --prefix apps/client run preview",
    "lint": "eslint . --ext .js,.jsx --max-warnings=0",
    "format": "prettier -w ."
  },
  "dependencies": {
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3"
  }
}
