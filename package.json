{
  "name": ".",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "diagnose": "node scripts/diagnose.mjs || echo diagnose stub",
    "heal": "node scripts/autoHealJson.mjs || echo heal stub",
    "verify": "node scripts/verify.mjs || echo verify stub",
    "server:start": "npm --prefix apps/server run dev",
    "client:start": "npm --prefix apps/client run dev",
    "start:all": "concurrently -k -n server,client \"npm --prefix apps/server run dev\" \"npm --prefix apps/client run dev\"",
    "start:heal": "npm run heal:json && npm install && npm run start:all",
    "heal:json": "node scripts/autoHealJson.mjs",
    "fix": "node scripts/autoheal-json.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "apps/*",
    "ops/*",
    "shared/*"
  ],
  "engines": {
    "node": ">=20"
  }
}
