{
  "name": "my-mental-health-buddy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["client"],
  "scripts": {
    "start": "node server/index.mjs",
    "build": "npm run build -w client",
    "dev": "npm run dev -w client",

    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",

    "kill-ports": "node scripts/clean-port.mjs",
    "ensure-tools": "node scripts/ensure-tools.mjs",
    "guardian": "node scripts/guardian-heart.mjs",
    "heal": "node scripts/permanent-fix.mjs",
    "check-package": "node scripts/check-package-json.mjs",
    "preflight": "node scripts/preflight.mjs",

    "build-and-start": "npm run build -w client && npm start",
    "safe-cycle": "npm run preflight && npm run ensure-tools && npm run heal && npm run guardian && npm run build-and-start",

    "heal-only": "node scripts/permanent-fix.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@tanstack/react-query": "^5.90.11",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.0",
    "drizzle-zod": "^0.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "openai": "^4.76.0",
    "pg": "^8.12.0",
    "stripe": "^16.0.0",
    "wouter": "^3.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.5",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.0",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.0"
  }
}