{
  "name": "mymentalhealthbuddy-monorepo",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev:server": "npm --prefix apps/server run dev",
    "dev:client": "npm --prefix apps/client run dev",
    "start:all": "concurrently -k -n server,client -c auto \"npm run dev:server\" \"wait-on http://localhost:5000/health && npm run dev:client\"",
    "build": "npm --prefix apps/client run build && npm --prefix apps/server run build",
    "start": "cross-env PORT=5000 NODE_ENV=production node dist/apps/server/src/index.js",
    "health": "node scripts/health.js"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^5.3.0",
    "@stripe/stripe-js": "^8.2.0",
    "@tailwindcss/vite": "^4.1.16",
    "@tanstack/react-query": "^5.90.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/express-session": "^1.18.2",
    "@types/helmet": "^0.0.48",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.15.5",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "express": "^4.19.2",
    "express-session": "^1.18.2",
    "express-static-gzip": "^3.0.0",
    "helmet": "^7.1.0",
    "lucide-react": "^0.548.0",
    "morgan": "^1.10.0",
    "openai": "^6.7.0",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "stripe": "^19.1.0",
    "vite-plugin-compression": "^0.5.1",
    "wouter": "^3.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.0",
    "wait-on": "^8.0.5"
  }
}
