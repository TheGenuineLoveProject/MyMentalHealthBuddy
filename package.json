{
  "name": "mymentalhealthbuddy-monorepo",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev:server": "npm --prefix apps/server run dev",
    "dev:client": "npm --prefix apps/client run dev",
    "dev:start": "npm run dev:server",
    "build": "npm run build:client && npm run build:server",
    "build:client": "npm --prefix apps/client run build",
    "build:server": "npm --prefix apps/server run build",
    "start": "NODE_ENV=production npm --prefix apps/server run start",
    "start:all": "concurrently -k -n server,client -c auto \"npm run dev:server\" \"wait-on http://localhost:5000/health && npm run dev:client\"",
    "build:all": "npm --prefix apps/client run build",
    "preview": "npm --prefix apps/client run preview",
    "lint": "eslint . --ext .js,.jsx --max-warnings=0",
    "format": "prettier -w ."
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@replit/vite-plugin-cartographer": "^0.4.0",
    "@replit/vite-plugin-dev-banner": "^0.1.1",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.3",
    "@tailwindcss/vite": "^4.1.16",
    "@tanstack/react-query": "^5.90.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/express-session": "^1.18.2",
    "@types/pg": "^8.15.5",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.7.4",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.5",
    "express": "^4.19.2",
    "express-session": "^1.18.2",
    "helmet": "^7.1.0",
    "lucide-react": "^0.548.0",
    "morgan": "^1.10.0",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.65.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16",
    "vite": "^7.1.12",
    "vite-plugin-compression": "^0.5.1",
    "wouter": "^3.7.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "wait-on": "^8.0.0"
  }
}
