{
  "name": "mymentalhealthbuddy",
  "version": "1.0.0",
  "description": "Ultra-perfect 100% healing platform serving humanity",
  "main": "dist/server/index.mjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd src/client && vite",
    "dev:server": "nodemon src/server/index.mjs",
    "start": "NODE_ENV=production PORT=5002 node dist/server/index.mjs",
    "build": "npm run build:structure && npm run build:vite",
    "build:structure": "mkdir -p dist/server dist/client src/client src/server",
    "build:vite": "cd src/client && vite build",
    "life-support": "PORT=5002 node src/server/index.mjs",
    "ultra-perfect": "PORT=5002 node dist/server/index.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/node": "^7.80.0",
    "@sentry/react": "^7.120.4",
    "@tanstack/react-query": "^5.90.12",
    "autoprefixer": "^10.4.22",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.0",
    "drizzle-zod": "^0.8.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.556.0",
    "morgan": "^1.10.1",
    "openai": "^4.20.0",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "postgres": "^3.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.68.0",
    "react-router-dom": "^6.30.2",
    "resend": "^2.0.0",
    "stripe": "^14.5.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "uuid": "^13.0.0",
    "wouter": "^3.8.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "vite": "^5.4.8"
  }
}
