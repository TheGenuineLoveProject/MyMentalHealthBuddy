{
  "name": "mymentalhealthbuddy",
  "version": "2.0.0",
  "type": "module",
  "main": "server/index.mjs",
  "scripts": {
    "dev": "NODE_ENV=development node server/index.mjs",
    "build": "vite build --config vite.config.js",
    "start": "NODE_ENV=production node server/index.mjs",
    "studio": "drizzle-kit studio --host 0.0.0.0 --port 4999",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "npm run db:push && npm run studio"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.30.9",
    "pg": "^8.11.3",
    "nodemon": "^3.1.11",
    "vite": "^5.4.2"
  }
}