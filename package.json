{
  "name": "mymentalhealthbuddy-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/server",
    "dev:client": "npm run dev -w apps/client",
    "build": "npm run build -ws",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "refine": "prettier --write .",
    "start:all": "npx concurrently -n SERVER,CLIENT -c cyan,magenta \"npm run dev -w apps/server\" \"npm run dev -w apps/client\""
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "vitest": "^2.1.2",
    "concurrently": "^8.2.2"
  }
}
