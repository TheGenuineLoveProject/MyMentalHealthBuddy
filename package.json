{
  "name": "mymentalhealthbuddy-monorepo",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run fixports && npm run dev:start",
    "dev:start": "concurrently -n SERVER,CLIENT -c cyan,magenta 'npm run start:server' 'npm run start:client'",
    "fixports": "npx kill-port 3000 3001 5000 9999 && sleep 2 || true",
    "start:server": "npm run dev -w apps/server",
    "start:client": "npm run dev -w apps/client",
    "start:all": "npm run dev",
    "build": "npm run build -w apps/client && npm run build -w apps/server",
    "start": "NODE_ENV=production node apps/server/dist/apps/server/src/index.js",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "kill-port": "^2.0.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "vite": "^7.1.12"
  }
}
