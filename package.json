{
  "name": "mymentalhealthbuddy",
  "version": "1.0.0",
  "type": "module",

  "scripts": {
    "start": "NODE_ENV=production node server/index.mjs",
    "dev": "NODE_ENV=development node server/index.mjs",

    "kill-ports": "node scripts/kill-ports.mjs",
    "platform-scan": "node scripts/platformScan.mjs",

    "autoheal": "node scripts/autoheal.mjs",
    "heal": "node scripts/autoheal-project.mjs",
    "heal:silent": "node scripts/autoheal.silent.mjs",

    "scan:api": "node scripts/scan-api.mjs",
    "scan:critical": "node scripts/scan-critical.mjs",
    "scan:types": "node scripts/scan-types.mjs",
    "scan:ui": "node scripts/scan-ui.mjs",
    "scan:vips": "node scripts/scan-vips.mjs",

    "scan": "node scripts/run-suite.js",
    "heal:full": "npm run heal:silent && npm run scan"
  },

  "workspaces": ["client", "server"],

  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.23.0",
    "drizzle-orm": "^0.30.0",
    "express": "^4.19.2",
    "helmet": "^7.1.3",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.55.0",
    "pg": "^8.12.0",
    "postgres": "^3.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "stripe": "^12.18.0",
    "zod": "^3.23.0"
  }
}