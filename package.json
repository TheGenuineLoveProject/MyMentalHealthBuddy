{
  "name": "mymentalhealthbuddy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "TS_NODE_TRANSPILE_ONLY=1 ts-node-dev --respawn --pretty --ignore-watch node_modules server/index.ts",
    "dev:client": "vite --port 5173",
    "build": "tsc -p .",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}