{
  "name": "mymentalhealthbuddy",
  "version": "1.0.0",
  "type": "module",
  "main": "server/index.mjs",
  "scripts": {
    "start": "NODE_ENV=production node server/index.mjs",
    "dev": "NODE_ENV=development node server/index.mjs",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio",
    "kill-ports": "node scripts/kill-ports.mjs",
    "platform-scan": "node scripts/platformScan.mjs",
    "autoheal": "node scripts/autoheal.mjs",
    "build": "npm run build --workspaces",
    "check-backend": "node scripts/check-backend.mjs",
    "check-frontend": "node scripts/check-frontend.mjs",
    "scan-errors": "node scripts/scan-errors.mjs",
    "diagnose": "node automation/orchestrator.mjs",
    "scan": "node scripts/run-suite.mjs",
    "heal": "node scripts/autoheal-project.mjs",
    "heal:full": "npm run heal && npm run scan"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "dependencies": {
    "@hookform/resolvers": "^3.3.2",
    "@sentry/node": "^8.17.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.104.0",
    "pg": "^8.11.4",
    "postgres": "^3.4.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "stripe": "^12.18.0",
    "zod": "^3.23.0"
  }
}
