{
  "name": "mymentalhealthbuddy-monorepo",
  "version": "1.1.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20 <21"
  },
  {
    "name": "mmhb-healer",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
      "scan": "ts-node scanner.ts",
      "orch": "ts-node orchestrator.ts"
    },
    "dependencies": {
      "@octokit/rest": "^19.0.0",
      "simple-git": "^3.13.0",
      "execa": "^7.1.1",
      "globby": "^13.2.2",
      "axios": "^1.4.0",
      "jsdom": "^22.1.0"
    },
    "devDependencies": {
      "ts-node": "^10.9.1",
      "typescript": "^5.1.6"
    }
  }
    {
      "scripts": {
        "start": "node apps/server/dist/apps/server/src/index.js",
        "dev": "npm-run-all -p dev:client dev:server",
        "dev:client": "npm --prefix apps/client run dev",
        "dev:server": "npm --prefix apps/server run dev",
        "build:client": "npm --prefix apps/client install && npm --prefix apps/client run build",
        "build:server": "npm --prefix apps/server install && npm --prefix apps/server run build",
        "build:production": "cross-env NODE_ENV=production npm run build:client && npm run build:server && echo \"🟢 Build complete — ready for Cloud Run\"",
        "db:push": "drizzle-kit push",
        "heal": "bash scripts/heal-now.sh",
    "start:all": "concurrently -k -n server,client -c auto \"npm run dev:server\" \"wait-on http://localhost:5000/health && npm run dev:client\"",
    "diagnose": "node scripts/diagnose.mjs",
    "verify": "node scripts/verify.mjs",
    "validate:apa": "node scripts/validate-apa.mjs",
    "s3:upload:covers": "node scripts/s3-uploader.mjs",
    "governor:v14": "node server/core/ai-governor-v14.mjs",
    "weekly:chain": "./scripts/weeklyMaster.sh",
    "nightly:chain": "./scripts/nightlyMaster.sh",
    "nightly:translate": "./scripts/translateNightly.sh",
    "compare:graphs": "node scripts/compareGraphs.mjs",
    "ai:summary": "node scripts/ai-summary.mjs",
    "tts:narrate": "node scripts/tts-narrate.mjs",
    "evolve:master": "./scripts/evolveMaster.sh",
    "social:auto-post": "node scripts/social-auto-post.mjs",
    "analytics:build": "node scripts/analytics-build.mjs",
    "analytics:watch": "chokidar 'logs/*.log' -c 'node scripts/analytics-build.mjs'",
    "compliance:loop": "node scripts/compliance-loop.mjs",
    "publish:daily": "node scripts/publish-daily.mjs",
    "analytics:open": "echo 'Open /public/analytics/index.html or /analytics in your client app'",
    "optimize": "echo '🔧 optimize: stub' && exit 0",
    "server": "npm run server:start || echo 'ℹ️ Define server:start to launch your API'",
    "client": "npm run client:start || echo 'ℹ️ Define client:start to launch your web app'",
    "build": "npm --prefix apps/client run build && npm --prefix apps/server run build",
    "build:client": "npm --prefix apps/client run build",
    "build:server": "npm --prefix apps/server run build",
    "build:analyze": "cross-env ANALYZE=true npm run build",
    "build:optimize": "npm run build && node scripts/optimize-build.js && node scripts/preload-optimizer.js",
    "build:production": "cross-env NODE_ENV=production npm run build:client && npm run build:server && node scripts/optimize-build.js && node scripts/preload-optimizer.js && node scripts/deployment-cleanup.js",
    "postbuild": "node scripts/deployment-cleanup.js",
    "start": "cross-env NODE_ENV=production node apps/server/dist/apps/server/src/index.js",
    "heal": "bash scripts/heal-now.sh",
    "production-check": "node scripts/production-check.js",
    "production-ready": "npm run build:production && npm run production-check",
    "setup:analytics": "node scripts/analytics-setup.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "health": "node scripts/health.js",
    "deploy:prepare": "npm run build:production && npm run production-check && echo '\n✅ Ready for deployment!'",
    "deploy:clean": "node scripts/deployment-cleanup.js && echo '\n✅ Deployment bundle optimized!'",
    "self-evolve": "npm run diagnose && npm run heal && npm run verify",
    "activate": "bash scripts/activateMaster.sh",
    "daily:publish": "node scripts/publish-daily.mjs",
    "ai:dashboard": "vite dashboards/ai-dashboard.jsx",
    "compliance": "node scripts/compliance-loop.mjs",
    "optimize:v12": "node scripts/optimizer.mjs",
    "social:approve": "node scripts/social-auto-post.mjs",
    "upload:images": "node scripts/s3-uploader.mjs",
    "publish": "node scripts/publisher.mjs",
    "heal:all": "node scripts/autoHeal.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.922.0",
    "@stripe/react-stripe-js": "^5.3.0",
    "@stripe/stripe-js": "^8.2.0",
    "@tailwindcss/vite": "^4.1.16",
    "@tanstack/react-query": "^5.90.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/express-session": "^1.18.2",
    "@types/helmet": "^0.0.48",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.15.5",
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.6",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "express": "^4.19.2",
    "express-session": "^1.18.2",
    "express-static-gzip": "^3.0.0",
    "form-data": "^4.0.4",
    "fs": "^0.0.1-security",
    "glob": "^11.0.3",
    "gray-matter": "^3.0.3",
    "helmet": "^7.1.0",
    "lucide-react": "^0.548.0",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.7.0",
    "path": "^0.12.7",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "stripe": "^19.1.0",
    "vite-plugin-compression": "^0.5.1",
    "web-vitals": "^5.1.0",
    "wouter": "^3.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.0",
    "gray-matter": "^4.0.3",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "wait-on": "^8.0.5"
  }
}
