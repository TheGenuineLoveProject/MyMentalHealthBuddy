// Safe, human-triggered content pack generator (dev-only)

import fs from "fs";
import path from "path";
import { fileURLToPath } from "url";
import OpenAI from "openai";

if (process.env.NODE_ENV === "production") {
  console.log("⚠️ Content automation disabled in production. Run in dev only.");
  process.exit(0);
}

if (!process.env.OPENAI_API_KEY) {
  console.log("❌ Missing OPENAI_API_KEY in your environment (.env).");
  console.log("Add: OPENAI_API_KEY=your-key-here");
  process.exit(1);
}

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const rootDir = path.resolve(__dirname, "..");
const outputDir = path.join(rootDir, "content_output");

if (!fs.existsSync(outputDir)) {
  fs.mkdirSync(outputDir, { recursive: true });
}

// CLI args
const topic = process.argv[2] || "self-love and everyday healing";
const audience =
  process.argv[3] || "stressed, sensitive humans who want to live in genuine love";

const iso = new Date().toISOString().replace(/:/g, "-");
const safeTopic = topic.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "") || "topic";
const fileName = `${iso}-${safeTopic}.md`;
const filePath = path.join(outputDir, fileName);

const openai = new OpenAI({ apiKey: process.env.OPENAI_API_KEY });

const systemPrompt = `
You are the dedicated content system for "The Genuine Love Project".
Tagline: "Live in Genuine Love".
Mission: Teach everyday self-love and healing using warm, compassionate, evidence-informed language.

Rules:
- You are NOT a therapist, not a doctor, and not crisis support.
- Never give diagnoses or direct medical/psychiatric advice.
- Encourage people to seek professional help and use crisis lines when needed.
- Tone: gentle, hopeful, grounded, trauma-aware, non-judgmental.
- Audience may include trauma survivors, highly sensitive people, and burned-out helpers.
- Avoid toxic positivity. Integrate validation + tiny, doable steps.

Output everything in clear Markdown sections.
`;

const userPrompt = `
Create a complete multi-platform content pack for The Genuine Love Project.

Topic: ${topic}
Audience: ${audience}

Please return Markdown with these sections:

# Master Concept
- 2–3 sentences explaining the key idea in simple words.

## Instagram Post + Caption
- A short post idea (visual description).
- 1 main caption (up to 180 words).
- 3–5 hashtag suggestions.

## TikTok/Reel Hooks
- 5 hook lines (each under 15 words).
- 3 simple on-screen text ideas.

## YouTube Title & Description
- 3 title options.
- 1 description (150–250 words) with a gentle CTA.

## Email Subject & Body
- 3 subject line options.
- 1 full email body (250–400 words), conversational and kind.

## Blog Outline
- A simple outline with H2/H3 headings.
- 3–5 bullet points under each heading.

## Disclaimers & Safety
- 3–4 bullet points reminding this is not therapy and sharing crisis-support guidance in generic form.

Use warm, human language. No emojis inside headings. Minimal emojis inside body text only if they feel natural.
`;

async function main() {
  console.log("🧠 Generating content pack for:", topic);
  console.log("👥 Audience:", audience);
  console.log("");

  try {
    const completion = await openai.chat.completions.create({
      model: "gpt-4.1-mini",
      messages: [
        { role: "system", content: systemPrompt },
        { role: "user", content: userPrompt }
      ],
      temperature: 0.7
    });

    const content = completion.choices[0]?.message?.content || "";

    if (!content.trim()) {
      console.log("❌ Got empty content from OpenAI.");
      process.exit(1);
    }

    fs.writeFileSync(filePath, content, "utf8");

    console.log("✅ Content pack generated!");
    console.log("📄 Saved to:", filePath);
    console.log("");
    console.log("Next: open the file, lightly edit, and schedule across your platforms.");
  } catch (err) {
    console.error("❌ Error while generating content pack:");
    console.error(err.message || err);
    process.exit(1);
  }
}

main();