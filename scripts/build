// @ts-check
#!/bin/bash
# Optimized build wrapper script for deployment
echo "🔨 Running 50^ optimized production build..."
echo "✅ Building MyMentalHealthBuddy for production deployment"
node build-prod.mjs

# Check if build succeeded
if [ $? -eq 0 ]; then
  echo "✅ Build completed successfully!"
  echo "📦 Deployment package ready at dist/"
  echo "🚀 Ready for production deployment"
else
  echo "❌ Build failed - please check the error messages above"
  exit 1
fi