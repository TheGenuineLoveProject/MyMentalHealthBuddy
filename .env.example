# Environment Configuration
NODE_ENV=development
PORT=5000

# Security
SESSION_SECRET=your-very-secure-secret-key-change-this-in-production

# Database (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,https://node-react-vite-MyMentalHealth.replit.app

# Logging
LOG_LEVEL=info

# API Configuration
API_RATE_LIMIT=100
ENABLE_API_DOCS=true

# --- Required ---
OPENAI_API_KEY=your_key_here

# --- Optional (fill when you wire them) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
DATABASE_URL=
JWT_SECRET=