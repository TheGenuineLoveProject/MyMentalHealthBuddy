# The Genuine Love Project — Environment Configuration
# Copy this file to .env and fill in your actual values

# --- Core ---
NODE_ENV=development
PORT=5000

# --- Database (required) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Security (required) ---
SESSION_SECRET=change-me-in-prod-min-32-chars

# --- OpenAI (required for AI chat) ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Stripe Payment Processing ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# --- Optional: Monitoring ---
SENTRY_DSN=
VITE_SENTRY_DSN=

# --- Optional: Email ---
RESEND_API_KEY=

# --- Optional: Canva Integration ---
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_APP_ORIGIN=

# --- CORS (for development) ---
CORS_ORIGIN=http://localhost:5173

# IMPORTANT NOTES:
# 1. Never commit .env file with real keys (already in .gitignore)
# 2. For Stripe test mode: use pk_test_ and sk_test_ keys
# 3. SESSION_SECRET should be at least 32 random characters
# 4. All VITE_ prefixed variables are exposed to the frontend
VITE_FIGMA_EMBED_URL=
FIGMA_TOKEN=
FIGMA_FILE_KEY=