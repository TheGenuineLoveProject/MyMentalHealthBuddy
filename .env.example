# ---------------------------------------------------------------------------
# MMHB — Environment variable reference
# Copy to .env and fill in real values for local development.
# Production secrets are managed by Replit Secrets, not committed to git.
# ---------------------------------------------------------------------------

# ----- Core runtime -----
NODE_ENV=development
PORT=5000

# Postgres (Neon) — provided automatically on Replit deployments
DATABASE_URL=

# Express session signing
SESSION_SECRET=

# JWT signing — also salts hashed identifiers in observability/safetyAlerts +
# OTel baggage, so two deploys never share the same hash space.
JWT_SECRET=

# Admin token for internal admin endpoints (operations console, runbooks)
ADMIN_TOKEN=

# ----- AI providers -----
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# ----- Observability: OpenTelemetry tracing -----
# Tracing is loaded via NODE_OPTIONS='--import ./server/observability/preload.mjs'.
# Set OTEL_DISABLED=true to skip SDK init entirely (no spans, no exporter).
# Default behaviour: SDK starts in noop-export mode unless OTEL_EXPORTER_*
# is configured, so it's always safe to leave disabled in development.
OTEL_DISABLED=false
OTEL_SERVICE_NAME=mmhb
# When set, tracing exports OTLP/HTTP to this endpoint (e.g. Honeycomb,
# Grafana Tempo, Jaeger). Leave blank in dev to keep spans local-only.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# ----- Observability: PagerDuty alerter -----
# Master switch for outbound PagerDuty calls. When false, sendAlert() logs
# the alert payload and dedup key but never makes a network call. Safe
# default for development and CI.
ALERTS_ENABLED=false
# Force PagerDuty calls even in non-production environments. Off by default
# so dev/staging never accidentally pages the on-call rotation.
ALERTS_FORCE=false
# Per-PagerDuty-service routing key. Required to actually page; without it
# the alerter logs and returns immediately even in production.
PAGERDUTY_ROUTING_KEY=
# Local dedup window: identical dedup keys collapse for this many ms.
# Default: 300000 (5 minutes). Read by server/observability/alerter.mjs.
ALERT_DEDUP_WINDOW_MS=300000

# ----- Stripe (billing) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Email (Resend) -----
RESEND_API_KEY=

# ----- GitHub OAuth (optional) -----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ----- Object storage (Replit-managed) -----
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# ----- Frontend (Vite — must be VITE_ prefixed) -----
VITE_GA_MEASUREMENT_ID=
