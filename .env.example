# The Genuine Love Project — Environment Configuration
# Copy this file to .env and fill in your actual values

# --- Core ---
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database (required) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_SSL=false

# --- Security (required) ---
SESSION_SECRET=change-me-in-prod-min-32-chars

# --- JWT Authentication ---
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Admin Access ---
ADMIN_TOKEN=your-admin-token-here

# --- OpenAI (required for AI chat) ---
OPENAI_API_KEY=your_openai_api_key_here
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key_here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_SYSTEM_PROMPT=

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- Stripe Payment Processing ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_PRICE_BASIC=price_basic_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_PREMIUM=price_premium_id
STRIPE_PRICE_TEAM=price_team_id

# --- Monitoring ---
SENTRY_DSN=
VITE_SENTRY_DSN=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# --- Canva Integration ---
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_APP_ORIGIN=
CANVA_APP_ID=
CANVA_HMR_ENABLED=false

# --- Figma Integration ---
VITE_FIGMA_EMBED_URL=
FIGMA_TOKEN=
FIGMA_FILE_KEY=

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- URLs ---
APP_BASE_URL=http://localhost:5000
PRODUCTION_URL=
REPLIT_DEV_DOMAIN=
HEALTH_URL=/healthz
SMOKE_BASE_URL=http://localhost:5000
TEST_URL=http://localhost:5000

# --- Redis (optional) ---
REDIS_URL=

# --- Security Options ---
ENABLE_CSRF=false

# --- Build/Deploy ---
BUILD_VERSION=dev
REPLIT_DEPLOYMENT=false
REPLIT_AI_API_URL=

# --- QA/Testing ---
VITE_QA_BYPASS_AUTH=false

# IMPORTANT NOTES:
# 1. Never commit .env file with real keys (already in .gitignore)
# 2. For Stripe test mode: use pk_test_ and sk_test_ keys
# 3. SESSION_SECRET should be at least 32 random characters
# 4. All VITE_ prefixed variables are exposed to the frontend
