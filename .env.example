# MyMentalHealthBuddy Environment Configuration
# Copy this file to .env and fill in your actual values

# Client Origin
CLIENT_ORIGIN=http://localhost:5173

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=your_postgres_connection_string_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Stripe Payment Processing
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# Optional: Stripe Webhook Secret (required for production webhook security)
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Session Secret (generate a random string for production)
SESSION_SECRET=your_secure_random_secret_key_here_min_32_chars

# Canva API - Visual Design & Social Media Content
# Get your credentials from: https://www.canva.com/developers/
CANVA_CLIENT_ID=your_canva_client_id_here
CANVA_CLIENT_SECRET=your_canva_client_secret_here
CANVA_REDIRECT_URI=http://localhost:5000/api/canva/callback
VITE_CANVA_ENABLED=true

# IMPORTANT NOTES:
# 1. Never commit .env file with real keys (already in .gitignore)
# 2. For Stripe test mode: use pk_test_ and sk_test_ keys
# 3. For Stripe live mode: use pk_live_ and sk_live_ keys  
# 4. SESSION_SECRET should be at least 32 random characters
# 5. All VITE_ prefixed variables are exposed to the frontend
# 6. Canva API enables visual design creation, social media content, and graphics generation

# Cross-platform publisher
WORDPRESS_URL=
WORDPRESS_TOKEN=
MEDIUM_TOKEN=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=
YOUTUBE_API_KEY=

## v13.5 — Cross-Network Tokens
# X (Twitter) — use OAuth2 Bearer (App or User context)
X_BEARER=
# Instagram (Business) via Facebook Graph
IG_ACCESS_TOKEN=
IG_IG_BUSINESS_ID=
# Threads (Meta) — token/user id (if available to you) — otherwise stub log
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
# Caption languages (comma list), e.g. "en,es,fr"
CAPTION_LANGS=en

# --- S3 STORAGE (used by AI Publisher + Image Host) ---
S3_ENDPOINT=https://<your-endpoint>         # e.g. https://nyc3.digitaloceanspaces.com
S3_REGION=us-east-1                         # your region
S3_BUCKET=mymentalhealthbuddy               # your bucket name
S3_ACCESS_KEY=                              # your access key
S3_SECRET_KEY=                              # your secret key
# ---- Core ----
NODE_ENV=development
JWT_SECRET=change_me
DATABASE_URL=postgres:///app

# ---- Optional: S3 / Spaces ----
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_REGION=us-east-1
S3_BUCKET=mymentalhealthbuddy
S3_ACCESS_KEY=your_key
S3_SECRET_KEY=your_secret

# --- Core ---
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# --- Secrets ---
SESSION_SECRET=change-me-in-prod
SENTRY_DSN=
STRIPE_SECRET_KEY=
OPENAI_API_KEY=
RESEND_API_KEY=
# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# shared/schema.ts
// Single source-of-truth Drizzle schema (TS)
import { pgTable, varchar, text, timestamp, uuid, boolean } from "drizzle-orm/pg-core";
import { sql } from "drizzle-orm";

export const users = pgTable("users", {
  id: uuid("id").primaryKey().defaultRandom(),
  name: varchar("name", { length: 255 }).notNull(),
  email: varchar("email", { length: 255 }).notNull().unique(),
  passwordHash: text("password_hash").notNull(),
  createdAt: timestamp("created_at", { withTimezone: true }).defaultNow().notNull(),
  updatedAt: timestamp("updated_at", { withTimezone: true }).defaultNow().notNull()
});

export const moods = pgTable("moods", {
  id: uuid("id").primaryKey().defaultRandom(),
  userId: uuid("user_id").notNull().references(() => users.id, { onDelete: "cascade" }),
  mood: varchar("mood", { length: 32 }).notNull(),
  note: text("note"),
  createdAt: timestamp("created_at", { withTimezone: true }).defaultNow().notNull()
});

export const journals = pgTable("journals", {
  id: uuid("id").primaryKey().defaultRandom(),
  userId: uuid("user_id").notNull().references(() => users.id, { onDelete: "cascade" }),
  title: varchar("title", { length: 255 }).notNull(),
  content: text("content").notNull(),
  createdAt: timestamp("created_at", { withTimezone: true }).defaultNow().notNull(),
  updatedAt: timestamp("updated_at", { withTimezone: true }).defaultNow().notNull()
});

export const aiMessages = pgTable("ai_messages", {
  id: uuid("id").primaryKey().defaultRandom(),
  userId: uuid("user_id").notNull().references(() => users.id, { onDelete: "cascade" }),
  role: varchar("role", { length: 16 }).notNull(),
  content: text("content").notNull(),
  createdAt: timestamp("created_at", { withTimezone: true }).defaultNow().notNull()
});

export const analytics = pgTable("analytics", {
  id: uuid("id").primaryKey().defaultRandom(),
  userId: uuid("user_id").notNull().references(() => users.id, { onDelete: "cascade" }),
  event: varchar("event", { length: 64 }).notNull(),
  meta: text("meta"),
  createdAt: timestamp("created_at", { withTimezone: true }).defaultNow().notNull()
});

export const passwordResetTokens = pgTable("password_reset_tokens", {
  id: uuid("id").primaryKey().defaultRandom(),
  userId: uuid("user_id").notNull().references(() => users.id, { onDelete: "cascade" }),
  tokenHash: text("token_hash").notNull(),
  expiresAt: timestamp("expires_at", { withTimezone: true }).notNull(),
  consumed: boolean("consumed").default(false).notNull(),
  createdAt: timestamp("created_at", { withTimezone: true }).defaultNow().notNull()
});

export const auditLog = pgTable("audit_log", {
  id: uuid("id").primaryKey().defaultRandom(),
  userId: uuid("user_id").references(() => users.id, { onDelete: "set null" }),
  action: varchar("action", { length: 64 }).notNull(),
  details: text("details"),
  createdAt: timestamp("created_at", { withTimezone: true }).defaultNow().notNull()
});

// Helpful view for DB check (no-op if not created)
export const ping = sql`select 1 as ok`;