# Dependencies
node_modules/
apps/*/node_modules/
**/node_modules/

# Build outputs (keep dist for deployment)
# dist/ - COMMENTED OUT - needed for deployment
# apps/*/dist/ - COMMENTED OUT - needed for deployment
*.tsbuildinfo
.rollup.cache/

# TypeScript compiled artifacts (prevent shadowing source files)
# Critical: Compiled .js/.jsx files in src/ can override .ts/.tsx imports
apps/*/src/**/*.js
apps/*/src/**/*.jsx
!apps/*/src/**/*.config.js  # Allow config files

# Environment variables
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# Self-evolution system
.rollback/
build-report.json
analytics-config.json

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
*.tmp
*.temp

# Testing
coverage/
.nyc_output/
__tests__/__coverage__/

# Cache
.cache/
.vite/
.turbo/
.pnpm/

# Backups
.backup/
*.tar.gz
*.zip

# Replit system directories (exclude from deployment)
.local/
.config/
.upm/
.cache/

# Source maps in production
*.map

# Database local files
*.sqlite
*.sqlite3
*.db
