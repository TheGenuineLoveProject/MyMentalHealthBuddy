# Dependencies
node_modules/

# Build output
# NOTE: client/dist/ and dist/ are intentionally tracked. Replit's deploy
# checkpoint snapshots the git tree into the build container; without these
# tracked, the runtime VM boots with no SPA bundle and the GET / health
# probe 404s before the boot-time rebuild can finish. See .replitignore
# header for the full rationale.
# client/dist/
# dist/

# Environment
.env
.env.local
.env.production
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test coverage
coverage/

# Quarantine
.quarantine/
_quarantine/
.backups_deleting/

# V20 cost optimization — orphan artifacts
audit-report.json
blog_templates.txt

# Local state
.local/
.cache/
.pythonlibs/

# Backups (kept on disk locally; never committed/shipped)
backups/
.backups_deleting/
archive/
reports/safe-backups/
*.bak

# User-uploaded reference images (path alias only; not bundled)
attached_assets/

# Temp files
*.tmp
*.temp

# Secrets
publickey.asc
gpg-batch

# Runtime data artifacts (additive guard: prevents NEW runtime memory/usage
# files from being tracked; does not retroactively untrack existing files).
/data/memory/
/data/memory-profile/
/data/memory-summary/
/data/usage/
/data/usage-*.json
*.jsonl

# Local archive of cleaned-up files (do not commit)
.archive/

# Audit / scratch artifacts (generated by scripts/platformAudit.mjs etc.)
audit-report.json
/*.html
/*.txt
!/README.md
reports/auth-guest-history-final.txt
client/dist/
.env
.env.*

# Local production backups - never commit
production-backups/
backups/
*.tar.gz

# Local-only backups
production-backups/
backups/
*.tar.gz

# ===== HX-OS GENERATED BACKUPS =====
.hx-backups/
backups/
production-backups/

# ===== GENERATED INVENTORY / SCANS =====
docs/inventory/*.txt
docs/inventory/**/*.txt

# ===== RUNTIME / CACHE =====
*.log
*.tmp
*.cache

# ===== BUILD OUTPUTS =====
dist/
build/
.tmp/

# ===== LOCAL DATABASES =====
*.sqlite
*.db


