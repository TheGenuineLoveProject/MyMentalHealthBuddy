# Dependencies
node_modules/

# Build output
client/dist/

# Environment
.env
.env.local
.env.production
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test coverage
coverage/

# Quarantine
.quarantine/
_quarantine/

# Local state
.local/
.cache/
.pythonlibs/

# Backups (kept on disk locally; never committed/shipped)
backups/
.backups_deleting/
archive/
reports/safe-backups/
*.bak

# User-uploaded reference images (path alias only; not bundled)
attached_assets/

# Temp files
*.tmp
*.temp

# Secrets
publickey.asc
gpg-batch

# Runtime data artifacts (additive guard: prevents NEW runtime memory/usage
# files from being tracked; does not retroactively untrack existing files).
/data/memory/
/data/memory-profile/
/data/memory-summary/
/data/usage/
/data/usage-*.json
*.jsonl

# Local archive of cleaned-up files (do not commit)
.archive/

# Audit / scratch artifacts (generated by scripts/platformAudit.mjs etc.)
audit-report.json
/*.html
/*.txt
!/README.md
