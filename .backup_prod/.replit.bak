entrypoint = "server/app.mjs"

run = "node server/app.mjs"

modules = ["nodejs-20"]

[[ports]]
localPort = 5000
externalPort = 80

[env]
NODE_ENV = "development"
PORT = "5000"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
