name: Platform Verification

on:
  push:
    branches:
      - main
      - master
  pull_request:

jobs:
  verify:
    runs-on: ubuntu-latest

    strategy:
      matrix:
        node-version: [20]

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: ${{ matrix.node-version }}

      - name: Install dependencies
        run: npm install

      - name: Build platform
        run: npm run build

      - name: Verify critical files
        run: |
          test -f package.json
          test -f .replit

      - name: Verify server entrypoint exists
        run: |
          test -f server/app.mjs || test -f server/index.js || test -f server/index.ts

      - name: Scan for duplicate listeners
        run: |
          COUNT=$(grep -R "app.listen(" server --include="*.js" --include="*.mjs" --include="*.ts" | wc -l)
          echo "listen count=$COUNT"
          if [ "$COUNT" -gt 2 ]; then
            echo "Too many listen() calls"
            exit 1
          fi

      - name: Verify health endpoints declared
        run: |
          grep -R "/api/health" server || exit 1

      - name: Verify no accidental localhost hardcoding
        run: |
          ! grep -R "localhost:3000" client server || exit 1

      - name: Verify no committed secrets
        run: |
          ! grep -R "OPENAI_API_KEY=" . --exclude-dir=node_modules || exit 1
