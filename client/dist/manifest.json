{
  "name": "MyMentalHealthBuddy - AI Mental Wellness Platform",
  "short_name": "MentalHealth",
  "description": "Your AI-powered mental wellness companion. Chat therapy, mood tracking, journaling, and professional support.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#0284c7",
  "orientation": "portrait-primary",
  "categories": ["health", "medical", "lifestyle", "productivity"],
  "lang": "en-US",
  "dir": "ltr",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Start Chat Session",
      "short_name": "Chat",
      "description": "Begin an AI therapy chat session",
      "url": "/chat",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Track Mood",
      "short_name": "Mood",
      "description": "Log your current mood",
      "url": "/mood",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Write Journal",
      "short_name": "Journal",
      "description": "Create a new journal entry",
      "url": "/journal",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Crisis Resources",
      "short_name": "Crisis",
      "description": "Access emergency mental health resources",
      "url": "/crisis",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard view on desktop"
    },
    {
      "src": "/screenshot-mobile.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Mobile chat interface"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "scope": "/",
  "serviceworker": {
    "src": "/sw.js",
    "scope": "/",
    "update_via_cache": "none"
  }
}
