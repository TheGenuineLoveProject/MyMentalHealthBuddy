{
  "name": "server",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "diagnose": "node scripts/diagnose.mjs || echo diagnose stub",
    "heal": "node scripts/heal.mjs || echo heal stub",
    "verify": "node scripts/verify.mjs || echo verify stub",
    "dev": "cross-env PORT=5000 node dist/apps/server/src/index.js",
    "build": "tsc",
    "server:start": "node apps/server/index.js || node server/index.js",
    "client:start": "vite --port 5173 --host 0.0.0.0 --strictPort",
    "start:all": "concurrently -k -n server,client \"npm:server:start\" \"npm:client:start\""
  },
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  }
}