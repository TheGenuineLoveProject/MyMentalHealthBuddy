run = "npm run start:all"
hidden = [".cache", "node_modules", ".pnpm"]
modules = ["nodejs-20", "postgresql-16"]

[agent]
expertMode = true
integrations = [
  "javascript_openai_ai_integrations:1.0.0",
  "javascript_stripe:1.0.0",
]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run start:all"
waitForPort = 5000

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 43255
externalPort = 3000

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build:production"]
