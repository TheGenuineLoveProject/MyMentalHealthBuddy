{
  "name": "mmhb-healer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "scan": "tsx scanner.ts",
    "heal": "tsx orchestrator.ts",
    "kb:reindex": "tsx utils/kb.ts",
    "heal:now": "echo 'Healing…' && tsx orchestrator.ts"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "axios": "^1.13.1",
    "execa": "^9.6.0",
    "globby": "^14.1.0",
    "jsdom": "^25.0.1",
    "simple-git": "^3.29.0",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "eslint": "^9.39.0",
    "npm-check-updates": "^17.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "description": "- **Scan**: `cd ops/healer && npm ci && npm run scan` - **Scan + Safe Fix + PR**: `cd ops/healer && npm ci && npm run heal` - Outputs: `ops/healer/output/*` - Configure repo/PR vars via env: `GH_TOKEN`, `GH_OWNER`, `GH_REPO`, `GH_BASE` (default `main`). - **Safety**: Auto-merge is **disabled**. Risky areas require human review per `policies.json`.",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
