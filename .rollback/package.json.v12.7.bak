{
  "name": "mymentalhealthbuddy-monorepo",
  "version": "1.1.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "ai:summary": "node scripts/ai-summary.mjs",
    "tts:narrate": "node scripts/tts-narrate.mjs",
    "evolve:master": "./scripts/evolveMaster.sh",
    "social:auto-post": "node scripts/social-auto-post.mjs",
    "analytics:build": "node scripts/analytics-build.mjs",
    "analytics:watch": "chokidar 'logs/*.log' -c 'node scripts/analytics-build.mjs'",
    "compliance:loop": "node scripts/compliance-loop.mjs",
    "publish:daily": "node scripts/publish-daily.mjs",
    "analytics:open": "echo 'Open /public/analytics/index.html or /analytics in your client app'",
    "diagnose": "node scripts/diagnose.mjs",
    "heal": "node scripts/heal.mjs",
    "verify": "node scripts/verify.mjs",
    "optimize": "echo '🔧 optimize: stub' && exit 0",
    "start:all": "concurrently -k -n server,client -c auto \"npm run dev:server\" \"wait-on http://localhost:5000/health && npm run dev:client\"",
    "server": "npm run server:start || echo 'ℹ️ Define server:start to launch your API'",
    "client": "npm run client:start || echo 'ℹ️ Define client:start to launch your web app'",
    "dev:server": "npm --prefix apps/server run dev",
    "dev:client": "npm --prefix apps/client run dev",
    "build": "npm --prefix apps/client run build && npm --prefix apps/server run build",
    "postbuild": "node scripts/deployment-cleanup.js",
    "build:analyze": "cross-env ANALYZE=true npm run build",
    "build:optimize": "npm run build && node scripts/optimize-build.js && node scripts/preload-optimizer.js",
    "build:production": "cross-env NODE_ENV=production npm run build:optimize",
    "start": "cross-env NODE_ENV=production node apps/server/dist/apps/server/src/index.js",
    "production-check": "node scripts/production-check.js",
    "production-ready": "npm run build:production && npm run production-check",
    "setup:analytics": "node scripts/analytics-setup.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "health": "node scripts/health.js",
    "deploy:prepare": "npm run build:production && npm run production-check && echo '\n✅ Ready for deployment!'",
    "deploy:clean": "node scripts/deployment-cleanup.js && echo '\n✅ Deployment bundle optimized!'",
    "self-evolve": "npm run diagnose && npm run heal && npm run verify",
    "activate": "bash scripts/activateMaster.sh",
    "daily:publish": "node scripts/publish-daily.mjs",
    "ai:dashboard": "vite dashboards/ai-dashboard.jsx",
    "compliance": "node scripts/compliance-loop.mjs",
    "optimize:v12": "node scripts/optimizer.mjs"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^5.3.0",
    "@stripe/stripe-js": "^8.2.0",
    "@tailwindcss/vite": "^4.1.16",
    "@tanstack/react-query": "^5.90.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/express-session": "^1.18.2",
    "@types/helmet": "^0.0.48",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.15.5",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "express": "^4.19.2",
    "express-session": "^1.18.2",
    "express-static-gzip": "^3.0.0",
    "glob": "^11.0.3",
    "helmet": "^7.1.0",
    "lucide-react": "^0.548.0",
    "morgan": "^1.10.0",
    "openai": "^6.7.0",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "stripe": "^19.1.0",
    "vite-plugin-compression": "^0.5.1",
    "web-vitals": "^5.1.0",
    "wouter": "^3.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.0",
    "wait-on": "^8.0.5"
  }
}