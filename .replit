# Replit monorepo launcher (Node + Vite)
modules = ["bash", "nodejs-20"]

run = "npm run dev"

# Must be an array of strings (TOML) – this fixes your earlier error
hidden = [".config", ".git", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["jq"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

# What Replit should proxy to the webview (vite dev server)
[ports]
previewPort = 5173