# 🌎 UNIVERSAL AUTO-HEAL + VITE DEPLOY CONFIG (2025)
run = "bash scripts/heal.sh || npm run dev"
entrypoint = "package.json"
modules = ["nodejs-20", "postgresql-16"]

[env]
HOST = "0.0.0.0"
PORT = "5173"
NODE_ENV = "development"

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd apps/server && NODE_ENV=production PORT=5000 node dist/index.js"]
build = ["bash", "-c", "cd apps/client && vite build --config vite.config.js && cd ../server && tsc -p tsconfig.json"]
