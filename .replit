# ===============================
# MyMentalHealthBuddy — Replit config
# Backend + Frontend + Autoscale
# ===============================

run = "npm start"

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build"]

# Autoscale port mapping
[[ports]]
localPort = 5000
externalPort = 80