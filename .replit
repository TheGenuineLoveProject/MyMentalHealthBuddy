# 💫 Replit Dual-Mode Launcher
# Run button = Heal Now system (development)
run = "bash scripts/heal-now.sh"

[env]
PLATFORM_NAME = "MyMentalHealthBuddy"
HEAL_MODE = "auto"
NODE_ENV = "production"

# --- Cloud Run (Autoscale) configuration ---
[nix]
channel = "stable-25_05"

[ports]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build:production"]