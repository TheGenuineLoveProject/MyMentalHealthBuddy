entrypoint = "server/index.mjs"

run = "echo '✨ Use npm run dev to start the server manually'"

modules = ["nodejs-20", "postgresql-15"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "install"]
run = ["npm", "start"]

[ports]
localPort = 5000
externalPort = 80

[env]
NODE_ENV = "development"