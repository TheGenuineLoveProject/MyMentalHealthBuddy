# .replit — TARGET CONFIG FOR AUTOSCALE

# 1) What runs when you click "Run" in the workspace:
run = "npm start"
entrypoint = "server/index.mjs"
modules = ["nodejs-20", "postgresql-16"]

# 2) Deployment config for Replit Autoscale:
[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["node", "server/index.mjs"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 41441
externalPort = 3000

# 4) (Optional but nice) Nix channel:
[nix]
channel = "stable-25_05"
packages = ["killall", "nano"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000
