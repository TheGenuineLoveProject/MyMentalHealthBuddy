# ──────────────────────────────
# 💫 Replit 360° Heal + Deploy
# ──────────────────────────────
# Local “Run” button ⇒ Heal system
run = "bash scripts/heal-now.sh"

[env]
PLATFORM_NAME = "MyMentalHealthBuddy"
HEAL_MODE = "auto"
NODE_ENV = "production"

# ── Cloud Run (Auto-scale) settings ──
[nix]
channel = "stable-25_05"

[ports]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build:production"]