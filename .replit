run = "node server/app.mjs"
modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "if [ ! -d node_modules/express ]; then npm install --omit=dev --no-audit --no-fund --prefer-offline; fi && node server/app.mjs"]
deploymentTarget = "vm"
build = ["sh", "-c", "npm run build"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
