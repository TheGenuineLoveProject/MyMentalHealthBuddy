# .replit — FINAL V7 AUTOSCALE CONFIG

run = "npm run start"

entrypoint = "server/index.mjs"

modules = ["nodejs-20", "postgresql-15"]

deployment = {
  deploymentTarget = "autoscale"
  build = ["npm", "run", "build"]
  run = ["npm", "start"]
}

ports = {
  localPort = 5000
  externalPort = 80
}

[env]
NODE_ENV = "production"

[workflows]

[workflows.run]
name = "Project"
mode = "parallel"
args = "start-application"

[workflows.tasks.start-application]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000