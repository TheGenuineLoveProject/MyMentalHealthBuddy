entrypoint = "server/app.mjs"
run = "npm run dev"
modules = ["nodejs-20", "postgresql-16", "python-3.11"]

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm install && npm run build"]
run = ["sh", "-c", "NODE_ENV=production NODE_OPTIONS='--import ./server/observability/preload.mjs' node server/app.mjs"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 24678
externalPort = 3000

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node --import ./server/observability/preload.mjs server/app.mjs"
waitForPort = 5000

[nix]
channel = "stable-25_05"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
