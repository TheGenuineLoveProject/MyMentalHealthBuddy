entrypoint = "server/app.mjs"
run = "npm run dev"
modules = ["nodejs-20", "postgresql-16", "python-3.11"]

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm ci --no-audit --no-fund && ls -d node_modules/express && npm run build"]
run = ["sh", "-c", "if [ ! -d node_modules/express ]; then echo '[boot] node_modules missing — running npm ci'; npm ci --omit=dev --no-audit --no-fund; fi; NODE_ENV=production node --import ./server/observability/preload.mjs server/app.mjs"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5099
externalPort = 3001

[[ports]]
localPort = 5198
externalPort = 3003

[[ports]]
localPort = 24678
externalPort = 3000

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node --import ./server/observability/preload.mjs server/app.mjs"
waitForPort = 5000

[nix]
channel = "stable-25_05"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
