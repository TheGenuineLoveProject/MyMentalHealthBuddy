run = "bash -lc 'npm run dev'"

[env]
PORT = "5000"
VITE_PORT = "5173"
NODE_ENV = "development"

[packager]
ignoredPaths = [".cache",".npm","node_modules","dist","client/dist"]

[ports]
previewPort = 5000

[nix]
channel = "stable-25_05"
packages = ["nodejs_20","bashInteractive","git","openssl","python3","glibcLocales"]

[agent]
expertMode = true
