entrypoint = "server/index.mjs"

run = "echo 'Use npm run dev to start the server manually'"
modules = ["nodejs-20", "python-3.11", "postgresql-16"]

[deployment]
deploymentTarget = "gce"
build = ["npm", "run", "build"]
run = ["node", "server/index.mjs"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 4200

[[ports]]
localPort = 5099
externalPort = 3002

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3001

[[ports]]
localPort = 5175
externalPort = 3000

[[ports]]
localPort = 24678
externalPort = 3003

[env]
NODE_ENV = "development"

[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0", "stripe:2.0.0", "perplexity_v0:1.0.0", "javascript_log_in_with_replit:2.0.0", "resend:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=development node server/dev.mjs"
waitForPort = 5000

[nix]
channel = "stable-25_05"
packages = ["lsof", "unzip", "python313Packages.pytest"]

[userenv]

[userenv.production]
NODE_ENV = "production"

[userenv.shared]
ADMIN_EMAILS = "marglanda92@yahoo.com"
