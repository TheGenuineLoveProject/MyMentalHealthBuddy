entrypoint = "server/index.mjs"

run = "echo 'Use npm run dev to start the server manually'"
modules = ["nodejs-20", "postgresql-16"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build", "-w", "client"]
run = ["node", "server/index.mjs"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 3000

[[ports]]
localPort = 5175
externalPort = 3001

[[ports]]
localPort = 33413
externalPort = 8000

[[ports]]
localPort = 33563
externalPort = 9000

[[ports]]
localPort = 33637
externalPort = 3003

[[ports]]
localPort = 34543
externalPort = 5173

[[ports]]
localPort = 36793
externalPort = 8008

[[ports]]
localPort = 39065
externalPort = 8080

[[ports]]
localPort = 39973
externalPort = 6000

[[ports]]
localPort = 41273
externalPort = 8081

[[ports]]
localPort = 42517
externalPort = 8099

[[ports]]
localPort = 43545
externalPort = 5000

[[ports]]
localPort = 44105
externalPort = 3002

[[ports]]
localPort = 44599
externalPort = 4200

[[ports]]
localPort = 46767
externalPort = 6800

[env]
NODE_ENV = "development"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=development node server/index.mjs"
waitForPort = 5000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.production]
NODE_ENV = "production"
