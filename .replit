run = "npm start"

entrypoint = "server/index.mjs"
modules = ["nodejs-20"]

[deployment]
deploymentTarget = "autoscale"
run = ["npm","start"]
build = ["npm","run","build"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

acceptedMimeTypes = ["text/html"]
