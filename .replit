# --- CLEAN REPLIT CONFIG (for Node 20 monorepo) ---

run = "npm run dev -w apps/server"
language = "nodejs"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"
packages = [
  "nodejs-20_x",
  "postgresql",
  "jq"
]

[env]
NODE_ENV = "development"
PORT = "5000"

[unitTest]
command = "npm run test"

[debug]
command = "npm run dev"

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 40329
externalPort = 3000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run start:all"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
