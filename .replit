run = "node dist/server.mjs"
modules = ["nodejs-20", "python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["node", "dist/server.mjs"]
deploymentTarget = "vm"
# PHASE115O7_REPLIT_DEPLOYMENT_CLEAN_BUILD_REPAIR
build = ["sh", "-c", "npm install && rm -rf dist client/dist && NODE_OPTIONS=--max-old-space-size=4096 npm run build && node scripts/build-server.mjs"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5055
externalPort = 3001

[[ports]]
localPort = 5098
externalPort = 3000

[[ports]]
localPort = 5099
externalPort = 3002

[[ports]]
localPort = 5156
externalPort = 3003

[[ports]]
localPort = 5157
externalPort = 4200

[[ports]]
localPort = 5998
externalPort = 5000

[[ports]]
localPort = 5999
externalPort = 5173

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

