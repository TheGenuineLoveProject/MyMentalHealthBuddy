# 💫 Replit 360° Heal + Deploy
run = "bash scripts/heal-now.sh"

[env]
PLATFORM_NAME = "MyMentalHealthBuddy"
NODE_ENV = "production"

[nix]
channel = "stable-25_05"

[ports]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build:production"]