run = "npm run start:all"
hidden = [".cache","node_modules",".pnpm"]
modules = ["nodejs-20"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev:server"
waitForPort = 5000

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 46157
externalPort = 3000

[nix]
channel = "stable-25_05"
